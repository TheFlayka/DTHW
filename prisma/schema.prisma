generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Suppliers {
  id Int @id @default(autoincrement())
  name String
  createdAt DateTime @db.Timestamptz(3)
  willCome DateTime @db.Timestamptz(3)
  willLeave DateTime @db.Timestamptz(3)
  timeSpent Int @default(0)
}